# .env file used for the docker/devel stack

MOSAICOD_STORE_ENDPOINT=http://localhost:9000
MOSAICOD_STORE_BUCKET=mosaico
MOSAICOD_STORE_ACCESS_KEY=admin
MOSAICOD_STORE_SECRET_KEY=password
MOSAICOD_DB_URL=postgresql://postgres:password@localhost:5432/mosaico

# Database connection pool size
MOSAICOD_MAX_DB_CONNECTIONS=10

# Maximum concurrent chunk queries during data catalog filtering
MOSAICOD_MAX_CONCURRENT_CHUNK_QUERIES=4

# Maximum chunk size in bytes before automatic splitting during upload.
# Set to 0 to disable (not recommended for large uploads).
# Default: 268435456 (256 MiB)
MOSAICOD_MAX_CHUNK_SIZE_IN_BYTES=268435456

# Configuration variable used by sqlx to establish a connection with the database for
# type checks
DATABASE_URL=postgresql://postgres:password@localhost:5432/mosaico
